# === CRITICAL: 시크릿/키 ===
.env
.env.*
*.env
**/.env
**/.env.*

# === 런타임/PID ===
*.pid
*.lock

# === OS 메타데이터 ===
.DS_Store
**/.DS_Store
Thumbs.db

# === Python ===
__pycache__/
**/__pycache__/
*.pyc
*.pyo
.venv/
**/.venv/
*.egg-info/
.pytest_cache/
**/.pytest_cache/

# === Node.js ===
node_modules/
**/node_modules/
npm-debug.log*
yarn-error.log*

# === 빌드 아티팩트 ===
build/
**/build/
dist/
**/dist/
dist-electron/
**/dist-electron/
release/
**/release/

# === 로컬 DB/벡터DB ===
data/bot.db
data/bot.db-shm
data/bot.db-wal
**/chroma_db/
*.db
*.db-shm
*.db-wal

# === Obsidian 내부 ===
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/graph.json

# === 아카이브 (API 키 포함 가능) ===
04_Archive/

# === 기타 ===
